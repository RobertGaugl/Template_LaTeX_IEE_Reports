%===============================================================================
% Lists
%===============================================================================
\newcommand{\tugrazlabelwidth}{7mm}

\setlist[itemize,1]{
  label=\makebox[\tugrazlabelwidth][l]{\raisebox{0.2ex}{\tiny$\blacksquare$}},
  labelsep=0pt,
  leftmargin=\dimexpr\tugrazlabelwidth+0.5em\relax,
  itemindent=0pt
}

\setlist[itemize,2]{
  label=\makebox[\tugrazlabelwidth][l]{\raisebox{0.2ex}{\tiny$\blacksquare$}},
  labelsep=0pt,
  leftmargin=\dimexpr\tugrazlabelwidth+0.5em\relax,
  itemindent=0pt
}

\setlist[itemize,3]{
  label=\makebox[\tugrazlabelwidth][l]{\raisebox{0.2ex}{\tiny$\blacksquare$}},
  labelsep=0pt,
  leftmargin=\dimexpr\tugrazlabelwidth+0.5em\relax,
  itemindent=0pt
}

