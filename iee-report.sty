%===============================================================================
% Bibliography
%===============================================================================
\RequirePackage[
  backend      = biber,
  style        = ieee,
  sorting      = none,
  natbib       = true,
  hyperref     = true,
  maxbibnames  = 3,
  dashed       = false
]{biblatex}
\addbibresource{./references.bib}

\DefineBibliographyStrings{german}{
  andothers = {et al.}
}

% Avoid broken links in bibliography
\setcounter{biburlnumpenalty}{100}
\setcounter{biburlucpenalty}{100}
\setcounter{biburllcpenalty}{100}


\AtEndPreamble{
        \renewcommand*{\bibfont}{\footnotesize}
        \setlength{\bibitemsep}{0.4em}
        \DeclareFieldFormat[inproceedings]{booktitle}{\color{grey}#1}
        \DeclareFieldFormat*{title}{\textbf{#1}}
        \renewbibmacro{in:}{}
}
