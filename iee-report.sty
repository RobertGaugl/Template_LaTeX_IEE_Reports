% -------------------------------------------------
% Cover page
% -------------------------------------------------
\newcommand{\makeieecover}{%
\newgeometry{
    left=1.5cm,
    right=1.5cm,
    top=2.4cm,
    bottom=1.5cm,
    includeheadfoot
}
\begin{titlepage}
    \thispagestyle{empty}
    \vspace*{-3.5cm}
    \noindent
    \makebox[\textwidth]{%
        \ieeiflogo[1.4cm]
        \hfill
        \includegraphics[height=1.4cm]{reportthemeiee/TU_Graz_Logo.pdf}
    }
    
    \begin{tikzpicture}[remember picture,overlay]
        \fill[blue] ([yshift=-3cm]current page.north west) rectangle ([yshift=-8cm]current page.north east);
        \fill[tug] ([yshift=-3.0cm]current page.north west) rectangle ([yshift=-3.25cm]current page.north east);
        \draw[blueLight, line width=1pt] ([xshift=1.5cm,yshift=-6.4cm]current page.north west) -- ([xshift=-1.5cm,yshift=-6.4cm]current page.north east);
    \end{tikzpicture}

    \vspace*{0.7cm}
    \noindent
    \begin{minipage}[b][2.2cm][b]{\textwidth}
        \color{white}\bfseries\fontsize{24}{28}\selectfont
        \reporttitle
    \end{minipage}

    \noindent
    \begin{minipage}[t][1.2cm][t]{\textwidth}
        \color{white}\fontsize{12}{15}\selectfont
        \reportsubtitle
    \end{minipage}

    \vfill

    \begin{tikzpicture}[remember picture,overlay]
        \fill[blueLight] ([yshift=-14cm]current page.north west) rectangle ([yshift=-19.5cm]current page.north east);
    \end{tikzpicture}


    {\hspace{5cm} \large \reportpartners\par}

    \vspace{1.2cm}

    \hspace{5cm}
    \begin{tabularx}{\textwidth}{@{}>{\bfseries}l X@{}}
        \ieeauthorslabel: & \reportauthors \\
        \ieeversionlabel: & \reportversion \\
        \ieelocationlabel: & \reportcity \\
        \ieedatelabel: & \reportmonth~\reportyear \\
    \end{tabularx}

    \vfill

    \begin{flushright}
        \begin{minipage}{\textwidth}
            \raggedleft

            \textcolor{blue}{\bfseries \ieeinstitutename}\\
            \textcolor{greyDark}{\ieeuniversity}\\[0.25em]
                        \textcolor{greyDark}{\ieeuniversityslogan}
        \end{minipage}
    \end{flushright}


    \begin{tikzpicture}[remember picture,overlay]
        \fill[blue] ([yshift=0cm]current page.south west) rectangle ([yshift=1cm]current page.south east);
    \end{tikzpicture}
\end{titlepage}
\restoregeometry
}

% -------------------------------------------------
% Imprint page
% -------------------------------------------------
\newcommand{\makeieeimprint}[1][]{%
    \thispagestyle{empty}%
    \begin{tikzpicture}[remember picture,overlay]
        \node[
            anchor=south west,
            xshift=3.65cm,
            yshift=3cm,
            inner sep=0pt
        ] at (current page.south west) {%
            \parbox[t]{15cm}{%
                \footnotesize
                \textbf{\ieeinstitutename}\\
                \ieeuniversity\\
                Inffeldgasse 18\\
                8010 Graz\\
                Austria\\[0.5em]
                Website: \href{https://iee.tugraz.at}{https://iee.tugraz.at}\\
                E-Mail: \href{mailto:iee@tugraz.at}{iee@tugraz.at}\\[1em]
                \copyright~IEE, TU Graz\\
                Graz, \reportmonth~\reportyear%
                \ifstrempty{#1}{}{%
                    \\[3em]
                    #1%
                }%
            }%
        };
    \end{tikzpicture}%
    \null
    \newpage
}


% -------------------------------------------------
% Back page
% -------------------------------------------------
\newcommand{\makeieebackpage}{%
\clearpage
\newgeometry{
    left=1.5cm,
    right=1.5cm,
    top=1.5cm,
    bottom=1cm,
}
\addtocounter{page}{-1}
\thispagestyle{empty}

\begin{tikzpicture}[remember picture,overlay]
    % Dark blue background
    \fill[blue] (current page.south west) rectangle (current page.north east);

    % Decorative translucent squares
    \fill[white, opacity=0.5] ([xshift=2.57cm,yshift=16.0cm]current page.south west) rectangle ++(5.0cm,5.0cm);
    \fill[white, opacity=0.5] ([xshift=8.00cm,yshift=16.0cm]current page.south west) rectangle ++(5.0cm,5.0cm);
    \fill[white, opacity=0.5] ([xshift=13.44cm,yshift=16.0cm]current page.south west) rectangle ++(5.0cm,5.0cm);

    \fill[white, opacity=0.5] ([xshift=5.06cm,yshift=13.51cm]current page.south west) rectangle ++(5.0cm,5.0cm);
    \fill[white, opacity=0.5] ([xshift=10.94cm,yshift=18.48cm]current page.south west) rectangle ++(5.0cm,5.0cm);

    % White footer bar
    \fill[white] ([yshift=1cm]current page.south west) rectangle ([yshift=3.15cm]current page.south east);

    % TU Graz red line
    \fill[tug] ([yshift=3.15cm]current page.south west) rectangle ([yshift=3.35cm]current page.south east);
\end{tikzpicture}


% Footer logos
\vspace*{\fill}
\noindent
\makebox[\textwidth]{%
    \ieeiflogo[1.1cm]
    \hfill
    \includegraphics[height=1.2cm]{reportthemeiee/TU_Graz_Logo.pdf}%
}
\begin{tikzpicture}[remember picture,overlay]
    \fill[blue] ([yshift=0cm]current page.south west) rectangle ([yshift=1cm]current page.south east);
\end{tikzpicture}

\restoregeometry
}

