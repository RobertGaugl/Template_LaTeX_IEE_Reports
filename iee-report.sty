% -------------------------------------------------
% Page geometry and spacing
% -------------------------------------------------
% Layout inspired by sidebar-style study reports:
% main text block on the right (~2/3), annotation / figure column on the left (~1/3)
\geometry{
  a4paper,
  left=7.0cm,
  right=2.2cm,
  top=2.4cm,
  bottom=2.6cm,
  marginparsep=0.45cm,
  marginparwidth=4.35cm,
  includeheadfoot
}
\reversemarginpar
\setlength{\marginparpush}{0.7cm}
\setstretch{1.08}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.45em}

% -------------------------------------------------
% Colors inspired by IEE / TU Graz
% Adjust to match your exact design specification if needed.
% -------------------------------------------------

% Colors are defined in a seperate file
\input{reportthemeiee/iee_colors}


% -------------------------------------------------
% Hyperref
% -------------------------------------------------
\hypersetup{
    colorlinks=true,
    linkcolor=black,
    urlcolor=url,
    citecolor=black
}
\urlstyle{same}
\renewcommand{\UrlFont}{\normalfont}

% -------------------------------------------------
% Headers / footers
% -------------------------------------------------
\pagestyle{fancy}
\fancyhfoffset[L]{4.8cm}
\fancyhf{}
\fancyhead[L]{\nouppercase{\textcolor{blue}\leftmark}}
% \fancyhead[R]{\textcolor{grey}{\thepage}}
\fancyfoot[L]{\textcolor{blue}{\ieeinstitutename}}
\fancyfoot[R]{\textcolor{blue}{\thepage}\textcolor{grey}{\ / \pageref*{LastPage}}}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}
\renewcommand{\headrule}{\hbox to\headwidth{\color{blueLight}\leaders\hrule height \headrulewidth\hfill}}
\renewcommand{\footrule}{\hbox to\headwidth{\color{blueLight}\leaders\hrule height \footrulewidth\hfill}}

\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyfoot[L]{\textcolor{blue}{\ieeinstitutename}}
  \fancyfoot[R]{\textcolor{blue}{\thepage}\textcolor{grey}{\ / \pageref*{LastPage}}}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0.4pt}
  \renewcommand{\footrule}{\hbox to\headwidth{\color{blueLight}\leaders\hrule height \footrulewidth\hfill}}
}

% -------------------------------------------------
% TOC style
% -------------------------------------------------
\renewcommand{\cftchapfont}{\bfseries}
\renewcommand{\cftsecfont}{}
\renewcommand{\cftchappagefont}{\bfseries}
\renewcommand{\cftsecpagefont}{}

\makeatletter
\let\iee@oldl@chapter\l@chapter
\renewcommand*{\l@chapter}[2]{%
  \needspace{4\baselineskip}%
  {\hypersetup{linkcolor=blue}\iee@oldl@chapter{#1}{#2}}%
}

\let\iee@oldl@section\l@section
\renewcommand*{\l@section}[2]{%
  {\hypersetup{linkcolor=black}\iee@oldl@section{#1}{#2}}%
}
\makeatother

% -------------------------------------------------
% Chapter / section styles
% -------------------------------------------------
\newcommand{\ieechapterrule}{%
  \noindent
  \hspace*{-4.8cm}%
  \textcolor{blueLight}{\rule{\dimexpr\paperwidth-2.2cm-2.2cm\relax}{0.4pt}}%
}

\titleformat{\chapter}[display]
  {\normalfont}
  {%
    \begin{tikzpicture}[baseline=(n.base)]
      \node[anchor=base west, text=blue, font=\bfseries\Huge] (n)
        at (0,0) {\thechapter.};
    \end{tikzpicture}
  }
  {0pt}
  {%
    \vspace{-1.3cm}%
    \color{blue}\bfseries\Huge
    \hspace*{1.5cm}%
    \parbox{\dimexpr\textwidth-1.5cm\relax}{\raggedleft}%
  }
  [\vspace{-0.8cm}\ieechapterrule]

\titleformat{name=\chapter,numberless}[display]
  {\normalfont}
  {}
  {0pt}
  {%
    \vspace{-1.3cm}%
    \color{blue}\bfseries\Huge
    \parbox{\textwidth}{\raggedleft}%
  }
  [\vspace{-0.8cm}\ieechapterrule]

\titlespacing*{\chapter}{0pt}{-1cm}{1.5em}

\titleformat{\section}
  {\Large\bfseries\color{title}}
  {\thesection}
  {0.8em}
  {}

\titleformat{\subsection}
  {\large\bfseries\color{subtitle}}
  {\thesubsection}
  {0.8em}
  {}


% -------------------------------------------------
% Layout helpers for study-style pages
% -------------------------------------------------
\newenvironment{fullwidth}{%
  \begin{adjustwidth}{-4.8cm}{0cm}%
}{%
  \end{adjustwidth}%
}

\newenvironment{twothirdswidth}{%
  \begin{adjustwidth}{0cm}{0cm}%
}{%
  \end{adjustwidth}%
}

\newcommand{\sidebarcolumnwidth}{\the\marginparwidth}

% -------------------------------------------------
% Sidebar boxes, notes, and figures
% -------------------------------------------------
\captionsetup[figure]{justification=raggedright,singlelinecheck=false}

\NewDocumentEnvironment{sideBlock}{O{blue} m +b}
{%
  \marginnote{%
    \begin{minipage}{\marginparwidth}
      \begin{tcolorbox}[
        enhanced,
        breakable,
        sharp corners,
        colback={#1Light},
        colframe={#1Dark},
        colbacktitle={#1},
        coltext={#1Dark},
        boxrule=0.6pt,
        left=1.5mm,
        right=1.5mm,
        top=1.2mm,
        bottom=1.2mm,
        toptitle=1.5mm,
        bottomtitle=1.5mm,
        fonttitle=\bfseries,
        coltitle=white,
        title={\small #2}
      ]
      \small #3
      \end{tcolorbox}
    \end{minipage}%
  }[0.5\baselineskip]%
}
{}


\NewDocumentEnvironment{sideNote}{O{blue} m +b}
{%
  \marginnote{%
    \begin{minipage}{\marginparwidth}
      \textcolor{#1}{\rule{\linewidth}{0.4pt}}\\[0.4em]
      {\color{#1}\bfseries \small #2\par}
      \small #3\\[0.4em]
      \textcolor{#1}{\rule{\linewidth}{0.4pt}}
    \end{minipage}
  }[0.5\baselineskip]%
}

\newcommand{\sideFigure}[5][]{%
  \marginnote{%
    \begin{minipage}{\marginparwidth}
      \textcolor{blue}{\rule{\linewidth}{0.4pt}}\\[0.4em]
      \ifstrequal{#5}{left}{\raggedright}{%
        \ifstrequal{#5}{right}{\raggedleft}{%
          \centering
        }%
      }%
      \ifstrempty{#1}
        {\includegraphics[width=\linewidth]{#2}}
        {\includegraphics[#1]{#2}}%
      \par
      \captionsetup{type=figure,font={bf,scriptsize},justification=raggedright,singlelinecheck=false}
      \ifstrempty{#3}{}{\captionof{figure}{#3}}%
      \ifstrempty{#4}{}{\label{#4}}%
      \textcolor{blue}{\rule{\linewidth}{0.4pt}}\\[0.4em]
    \end{minipage}%
  }[0.5\baselineskip]%%
}

\newcommand{\sideIcon}[2]{%
  \marginnote{%
    \begin{minipage}{\marginparwidth}
      \ifstrequal{#2}{left}{\raggedright}{%
        \ifstrequal{#2}{right}{\raggedleft}{%
          \centering
        }%
      }%
      #1\par
    \end{minipage}%
  }[0.5\baselineskip]%%
}

\newcommand{\sideTable}[2]{%
  \marginnote{%
    \begin{minipage}{\marginparwidth}
      \captionsetup{type=table,font={bf,scriptsize},justification=raggedright,singlelinecheck=false}
      #1
      \captionof{table}{#2}
    \end{minipage}%
  }[0.5\baselineskip]%%
}

\newtcolorbox{coloredBlock}[2][blue]{%
  enhanced,
  breakable,
  sharp corners,
  colback={#1Light},
  colframe={#1Dark},
  colbacktitle={#1},
  boxrule=0.5pt,
  left=2mm,
  right=2mm,
  top=1.5mm,
  bottom=1.5mm,
  toptitle=2mm,
  bottomtitle=2mm,
  fonttitle=\bfseries,
  coltext={#1Dark},
  coltitle=white,
  title={#2}
}

\newcommand{\ieeline}{%
  \par\vspace{0.5em}%
  \noindent
  \hspace*{-\dimexpr 1in+\hoffset+\oddsidemargin\relax}%
  \hspace*{2.2cm}%
  \textcolor{blueLight}{\rule{\dimexpr\paperwidth-2.2cm-2.2cm\relax}{0.4pt}}%
  \par\vspace{0.5em}%
}

